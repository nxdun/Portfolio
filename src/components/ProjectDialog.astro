---
import { slugifyStr } from "@/utils/slugify";
import { getTagHue, getTagIcon, getUiIcon } from "@/utils/projectUtils";
import Loader from "./Loader.astro";
import IconX from "@/assets/icons/IconX.svg";

type Props = {
  project: {
    project_name: string;
    short_desc: string;
    full_desc?: string;
    tags: {
      icon: { name: string; iconName: string }[];
      noIcon: string[];
    };
    urls: {
      label: string;
      url: string;
      description: string;
      iconName?: string | null;
    }[];
    time_period: string;
    photos?: string[];
  };
};

const { project } = Astro.props;
const { project_name, short_desc, full_desc, tags, urls, time_period, photos } =
  project;

const projectId = slugifyStr(project_name);
const dialogId = `dialog-${projectId}`;
const hasUrls = Array.isArray(urls) && urls.length > 0;
---

<dialog
  id={dialogId}
  tabindex="-1"
  aria-modal="true"
  class="project-dialog fixed z-50 m-auto h-full max-h-none w-full max-w-none overflow-hidden bg-background p-0 text-foreground shadow-2xl outline-none backdrop:bg-black/50 backdrop:backdrop-blur-sm md:h-auto md:max-h-[90vh] md:w-[90vw] md:max-w-3xl md:rounded-xl md:border md:border-border"
>
  <div class="flex h-full max-h-full flex-col">
    <!-- Header with Title and Close Button -->
    <div
      class="sticky top-0 z-10 border-b border-border bg-background px-6 py-4"
    >
      <div class="flex items-start justify-between">
        <div class="flex-1">
          <h2 class="text-xl font-bold text-accent sm:text-2xl">
            {project_name}
          </h2>
          <p class="mt-1 text-sm text-foreground/70">{time_period}</p>
        </div>

        <form method="dialog" class="ml-4">
          <button
            id={`dialog-close-${projectId}`}
            data-dialog-close
            class="rounded-full p-2 transition-colors hover:bg-muted focus:outline-none"
            aria-label="Close modal"
          >
            <IconX class="size-6" />
          </button>
        </form>
      </div>

      <!-- Project URLs (Horizontal Cards) -->
      {
        hasUrls && (
          <div class="mt-4 flex flex-wrap items-center gap-2.5">
            {urls.map(link => {
              const IconImg = link.iconName
                ? getUiIcon(link.iconName) || getTagIcon(link.iconName)
                : null;
              const linkText = link.description?.trim() || link.label;
              return (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-full bg-accent/12 px-3.5 py-2 text-sm leading-none font-medium text-accent transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent hover:text-white focus-visible:ring-2 focus-visible:ring-accent/60 focus-visible:outline-none"
                  title={link.description}
                >
                  {IconImg ? (
                    <span
                      class="icon-container block size-4.5 shrink-0"
                      set:html={IconImg}
                    />
                  ) : (
                    <svg
                      class="size-4 shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4m-4-6l6-6m0 0l-6 6"
                      />
                    </svg>
                  )}
                  <span>{linkText}</span>
                </a>
              );
            })}
          </div>
        )
      }
    </div>

    <!-- Main Content -->
    <div class="flex-1 space-y-6 overflow-y-auto p-6">
      <!-- Description -->
      <div class="prose max-w-none dark:prose-invert">
        <p class="leading-relaxed">{full_desc || short_desc}</p>
      </div>

      <!-- Tags Section -->
      <div class="flex flex-wrap gap-2">
        {
          tags.icon.map(t => {
            const IconImg = getTagIcon(t.iconName);
            return (
              <span
                class="flex items-center justify-center p-1 transition-all hover:scale-110"
                title={t.name}
              >
                {IconImg && (
                  <span
                    class="icon-container block size-8"
                    set:html={IconImg}
                  />
                )}
              </span>
            );
          })
        }
        {
          tags.noIcon.map(tag => (
            <span
              class="project-tag rounded-md px-3 py-1.5 text-base"
              style={`--tag-hue: ${getTagHue(tag)}`}
            >
              {tag}
            </span>
          ))
        }
      </div>

      <!-- Gallery Section -->
      {
        photos && photos.length > 0 && (
          <div class="space-y-4 pt-6">
            <h3 class="border-b border-border pb-2 text-lg font-semibold">
              Gallery
            </h3>
            <div class="grid grid-cols-1 gap-6">
              {photos.map(url => (
                <div
                  class="image-wrapper relative flex min-h-75 w-full flex-col items-center justify-center overflow-hidden rounded-lg bg-background"
                  data-src={url}
                >
                  <div class="pointer-events-none absolute inset-0 z-0 h-full w-full">
                    <Loader
                      mode="attached"
                      isSkeleton={true}
                      spotlight="none"
                      class="h-full w-full bg-transparent!"
                    />
                  </div>
                </div>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </div>
</dialog>

<style>
  /* Ensure the loader conforms fully to the image aspect ratio skeletons */
  .image-wrapper :global(.loader-container) {
    height: 100%;
    margin: 0;
  }
  .image-wrapper :global(.loader-frame) {
    min-height: 100% !important;
    background: transparent !important;
    border-radius: 0;
  }
  .image-wrapper :global(.loader-reveal) {
    min-height: 100% !important;
  }
</style>

<script>
  const initProjectDialogs = () => {
    const dialogs = document.querySelectorAll("dialog.project-dialog");

    const focusableSelector = [
      "a[href]",
      "area[href]",
      'input:not([disabled]):not([type="hidden"])',
      "select:not([disabled])",
      "textarea:not([disabled])",
      "button:not([disabled])",
      "iframe",
      "object",
      "embed",
      '[tabindex]:not([tabindex="-1"])',
    ].join(",");

    const getFocusable = (container: Element): HTMLElement[] => {
      const els = Array.from(
        container.querySelectorAll(focusableSelector)
      ) as HTMLElement[];
      return els.filter(el => {
        return (
          el instanceof HTMLElement &&
          (el.offsetWidth > 0 || el.offsetHeight > 0) &&
          el.getAttribute("aria-hidden") !== "true"
        );
      });
    };

    interface DialogWithHandler extends HTMLDialogElement {
      _onDialogKeyDown?: (ev: KeyboardEvent) => void;
    }

    const setupDialogKeyboard = (dialog: DialogWithHandler) => {
      const onKeyDown = (ev: KeyboardEvent) => {
        if (ev.key === "Escape") {
          dialog.close();
          return;
        }

        if (ev.key !== "Tab") return;

        const focusableElements = getFocusable(dialog);
        if (focusableElements.length === 0) {
          ev.preventDefault();
          return;
        }

        const firstElement = focusableElements[0];
        const lastElement = focusableElements[focusableElements.length - 1];

        if (!ev.shiftKey && document.activeElement === lastElement) {
          ev.preventDefault();
          firstElement.focus();
        } else if (ev.shiftKey && document.activeElement === firstElement) {
          ev.preventDefault();
          lastElement.focus();
        }
      };

      dialog.addEventListener("keydown", onKeyDown);
      return onKeyDown;
    };

    const loadDialogImages = (dialog: DialogWithHandler) => {
      const wrappers = dialog.querySelectorAll(".image-wrapper:not(.loaded)");
      if (wrappers.length === 0) return;

      wrappers.forEach(wrapper => {
        const url = wrapper.getAttribute("data-src");
        if (!url) return;

        const img = document.createElement("img");
        img.src = url;
        img.className =
          "relative z-10 w-full h-auto rounded-lg opacity-0 transition-opacity duration-500 bg-background cursor-zoom-in";
        img.loading = "lazy";
        img.alt = "Project Screenshot";

        img.addEventListener("click", () => {
          const event = new CustomEvent("open-image-viewer", {
            detail: { src: url },
          });
          window.dispatchEvent(event);
        });

        const onImageLoad = () => {
          img.classList.remove("opacity-0");

          // Let the image push the height properly, and fade out the underlying loader
          const loader = wrapper.querySelector("[data-loader]") as HTMLElement;
          if (loader && window.LoaderManager) {
            const manager =
              loader.__loaderManager || new window.LoaderManager(loader);
            manager.hide().then(() => {
              loader.remove();
            });
          }
        };

        img.addEventListener("load", onImageLoad);
        img.addEventListener("error", onImageLoad); // Optional: handles broken links smoothly

        wrapper.appendChild(img);
        wrapper.classList.add("loaded");
      });
    };

    dialogs.forEach(d => {
      const dialog = d as DialogWithHandler;
      if (dialog.dataset.initialized === "true") return;
      dialog.dataset.initialized = "true";

      dialog.addEventListener("click", (e: MouseEvent) => {
        if (e.target === dialog) dialog.close();
      });

      const observer = new MutationObserver(mutations => {
        mutations.forEach(mutation => {
          if (mutation.attributeName !== "open") return;

          if (dialog.open) {
            const closeBtn = dialog.querySelector("[data-dialog-close]");
            const focusables = getFocusable(dialog);
            const firstElement = focusables[0] || closeBtn || dialog;

            try {
              (firstElement as HTMLElement).focus({ preventScroll: true });
            } catch {
              // Ignore focus errors
            }

            dialog._onDialogKeyDown = setupDialogKeyboard(dialog);
            loadDialogImages(dialog);
          } else if (dialog._onDialogKeyDown) {
            dialog.removeEventListener("keydown", dialog._onDialogKeyDown);
            delete dialog._onDialogKeyDown;
          }
        });
      });

      observer.observe(dialog, { attributes: true });
    });
  };

  initProjectDialogs();
  document.addEventListener("astro:page-load", initProjectDialogs);
</script>
