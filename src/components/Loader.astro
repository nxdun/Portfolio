---
import LoaderSvg from "@/assets/icons/LoaderPacman.svg?raw";

interface Props {
  mode?: "attached" | "screen" | "overlay" | "background";
  globalHover?: boolean;
  spotlight?: "hover" | "always" | "none";
  animation?: boolean;
  sweep?: boolean;
  edgeHighlight?: boolean;
  content?: string;
  contentHref?: string;
  showIcon?: boolean;
  isSkeleton?: boolean;
  class?: string;
  label?: string;
  message?: string;
}

const {
  mode = "attached",
  globalHover = false,
  spotlight = "hover",
  animation = false,
  sweep = mode === "attached",
  edgeHighlight = mode === "attached",
  content = null,
  contentHref = undefined,
  showIcon = undefined,
  isSkeleton = false,
  class: className = "",
  label = "Loading",
  message,
} = Astro.props;

const boolAttr = (value: boolean) => (value ? "true" : "false");
const loaderContent = content ?? (showIcon ? LoaderSvg : null);
const isContentHtml =
  typeof loaderContent === "string" && loaderContent.trim().startsWith("<");
const hasContent = Boolean(loaderContent);
const isOverlay = mode === "overlay";
const isScreen = mode === "screen";
const isBackground = mode === "background";
const isAttached = !isOverlay && !isScreen && !isBackground;
const spotlightEnabled = spotlight !== "none";
---

<div
  class:list={[
    "loader-container",
    {
      "loader-container--attached": isAttached,
      "loader-container--screen": isScreen,
      "loader-container--overlay": isOverlay,
      "loader-container--background": isBackground,
      "loader-container--skeleton": isSkeleton,
    },
    className,
  ]}
  data-loader
  role="status"
  aria-live="polite"
  aria-busy="true"
  aria-label={label}
  data-loader-spotlight={spotlight}
  data-loader-global-hover={boolAttr(globalHover || isScreen)}
  data-loader-animation={boolAttr(animation)}
  data-loader-sweep={boolAttr(sweep)}
  data-loader-edge={boolAttr(edgeHighlight)}
  data-loader-content={boolAttr(hasContent)}
  data-loader-skeleton={boolAttr(isSkeleton)}
  data-loader-state="enter"
>
  <div class="loader-frame">
    <div class="loader-reveal">
      <div class="loader-grid-container" aria-hidden="true">
        <span class="loader-grid"></span>

        {sweep && <span class="loader-sweep" />}

        {spotlightEnabled && <span class="loader-spotlight" />}

        {edgeHighlight && <span class="loader-edge" />}
      </div>

      {
        hasContent && (
          <span class="loader-icon">
            {contentHref ? (
              <a class="loader-action" href={contentHref}>
                {isContentHtml ? (
                  <span set:html={loaderContent} />
                ) : (
                  loaderContent
                )}
              </a>
            ) : isContentHtml ? (
              <span set:html={loaderContent} />
            ) : (
              loaderContent
            )}
          </span>
        )
      }

      {
        message && (
          <div class="loader-content">
            <p class="loader-message">{message}</p>
          </div>
        )
      }
    </div>
  </div>
</div>

<style>
  .loader-container {
    --loader-grid-size: 20px;
    --loader-dot-size: 1px;
    --loader-dot-blur: 1.4px;
    --loader-dot-color: color-mix(in srgb, var(--foreground) 12%, transparent);
    --loader-highlight-color: color-mix(in srgb, var(--accent) 90%, white);
    --loader-highlight-blur: 1.35px;
    --loader-text-color: var(--accent);

    width: 100%;
    height: 100%;
    color: var(--accent);
  }

  html[data-theme="dark"] .loader-container {
    --loader-dot-color: color-mix(in srgb, var(--foreground) 16%, transparent);
  }

  .loader-container.fade-out {
    opacity: 0;
    transition: opacity 500ms ease-in-out;
  }

  .loader-container[data-loader-state="enter"] {
    opacity: 1;
  }

  .loader-container[data-loader-state="exit"] {
    opacity: 0;
  }

  .loader-container--overlay {
    position: fixed;
    inset: 0;
    z-index: 70;
    background: var(--background);
  }

  .loader-container--background {
    position: fixed;
    inset: 0;
    z-index: -10;
    pointer-events: none;
    background: var(--background);
  }

  .loader-frame {
    position: relative;
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    min-height: 8rem;
    overflow: hidden;
    isolation: isolate;
    border-radius: inherit;
    background: var(--background);
  }

  .loader-reveal {
    position: relative;
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    min-height: inherit;
    container-type: size;
  }

  .loader-grid-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
    clip-path: circle(0px at 50% 50%);
    transition: clip-path 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .loader-container[data-loader-state="enter"] .loader-grid-container,
  .loader-container[data-loader-state="ready"] .loader-grid-container {
    clip-path: circle(150vmax at 50% 50%);
  }

  .loader-container[data-loader-state="exit"] .loader-grid-container {
    clip-path: circle(0px at 50% 50%);
    transition-duration: 400ms;
  }

  .loader-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1.5rem;
    text-align: center;
    opacity: 0;
    transform: scale(0.96);
    transition:
      opacity 400ms ease,
      transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .loader-container[data-loader-state="enter"] .loader-content,
  .loader-container[data-loader-state="ready"] .loader-content {
    opacity: 1;
    transform: scale(1);
    transition-delay: 150ms;
  }

  .loader-container[data-loader-state="exit"] .loader-content {
    opacity: 0;
    transform: scale(0.96);
    transition-delay: 0ms;
    transition-duration: 300ms;
  }

  .loader-container--screen .loader-frame,
  .loader-container--overlay .loader-frame,
  .loader-container--background .loader-frame {
    min-height: 100svh;
    border-radius: 0;
  }

  .loader-grid,
  .loader-sweep,
  .loader-edge,
  .loader-spotlight {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .loader-icon {
    position: absolute;
    inset: 0;
    pointer-events: auto;
    display: none;
    place-items: center;
    opacity: 0;
    transition: opacity 300ms ease;
    color: var(--loader-text-color);
  }

  .loader-action {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    color: inherit;
    text-decoration: none;
    font: inherit;
    padding: 0 1rem;
  }

  .loader-action:hover,
  .loader-action:focus-visible {
    outline: none;
    text-decoration: none;
  }

  .loader-grid {
    opacity: 0.66;
    transition: opacity 300ms ease;
    background-image:
      radial-gradient(
        circle,
        var(--loader-dot-color) var(--loader-dot-size),
        transparent var(--loader-dot-blur)
      ),
      radial-gradient(circle at 50% 50%, transparent 0, transparent 100%);
    background-attachment: scroll;
    background-position:
      0 0,
      center;
    background-size:
      var(--loader-grid-size) var(--loader-grid-size),
      100% 100%;
  }

  .loader-container[data-loader-skeleton="true"] .loader-frame {
    background: var(--background);
  }
  .loader-container[data-loader-skeleton="true"] .loader-spotlight {
    display: none;
  }
  .loader-container[data-loader-skeleton="true"] .loader-grid,
  .loader-container[data-loader-skeleton="true"] .loader-sweep,
  .loader-container[data-loader-skeleton="true"] .loader-edge {
    background-position: var(--bg-x, 0px) var(--bg-y, 0px) !important;
  }
  .loader-container--background .loader-grid,
  .loader-container--background .loader-spotlight {
    position: fixed;
    inset: 0;
  }
  @media (hover: hover) and (pointer: fine) {
    .loader-container[data-loader-skeleton="true"]:hover .loader-sweep {
      opacity: 0.35;
    }
  }
  html[data-theme="dark"] .loader-grid {
    opacity: 0.54;
  }

  .loader-spotlight {
    opacity: 0;
    background-image: radial-gradient(
      circle,
      var(--loader-highlight-color) var(--loader-dot-size),
      transparent var(--loader-highlight-blur)
    );
    background-position: 0 0;
    background-size: var(--loader-grid-size) var(--loader-grid-size);
    background-attachment: scroll;
    --mask: radial-gradient(
      circle var(--loader-spotlight-size, 96px) at
        var(--loader-spotlight-x, 50%) var(--loader-spotlight-y, 50%),
      #000 0,
      #000 34%,
      transparent 58%
    );
    -webkit-mask-image: var(--mask);
    mask-image: var(--mask);
    transition: opacity 800ms ease;
  }

  html:has(.loader-container[data-loader-skeleton="true"]:hover)
    .loader-container--background
    .loader-spotlight {
    opacity: 0 !important;
  }

  .loader-container[data-loader-spotlight="always"] .loader-spotlight,
  .loader-container[data-loader-spotlight="hover"].loader-spotlight-active
    .loader-spotlight {
    opacity: 0.95;
  }

  @media (prefers-reduced-motion: reduce) {
    .loader-spotlight {
      transition: none;
    }
  }

  .loader-message {
    max-width: 28rem;
    font-size: 0.95rem;
    line-height: 1.5;
    color: color-mix(in srgb, var(--foreground) 78%, transparent);
    clip-path: inset(0 100% 0 0);
    opacity: 0;
    animation: loader-message-in 280ms steps(16, end) forwards;
  }

  .loader-container[data-loader-state="exit"] .loader-message {
    animation: loader-message-out 220ms steps(14, end) forwards;
  }

  .loader-sweep {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background-image: radial-gradient(
      circle,
      var(--loader-highlight-color) var(--loader-dot-size),
      transparent var(--loader-highlight-blur)
    );
    background-position: 0 0;
    background-size: var(--loader-grid-size) var(--loader-grid-size);
    --mask: linear-gradient(90deg, transparent 0%, #000 50%, transparent 100%);
    -webkit-mask-image: var(--mask);
    mask-image: var(--mask);
    -webkit-mask-size: 250% 100%;
    mask-size: 250% 100%;
    transition: opacity 300ms ease;
  }

  .loader-container[data-loader-state="ready"] .loader-sweep {
    opacity: 0.9;
    animation: sweep-back-and-forth 1.6s 1 ease-in-out;
  }

  @media (prefers-reduced-motion: no-preference) {
    .loader-container[data-loader-animation="true"]:not(:hover) .loader-grid {
      animation: grid-nebula-drift 12s infinite linear;
    }

    .loader-container[data-loader-animation="true"]:not(:hover)
      .loader-spotlight {
      animation: spotlight-breathe 3.6s infinite ease-in-out;
    }

    .loader-container[data-loader-animation="true"]:not(:hover) .loader-icon {
      animation: icon-levitate 2.8s infinite ease-in-out;
    }
  }

  .loader-container[data-loader-animation="true"][data-loader-sweep="true"]:not(
      :hover
    )
    .loader-sweep {
    opacity: 0.5;
    animation: sweep-back-and-forth 2.2s infinite ease-in-out;
  }

  .loader-container[data-loader-animation="true"]:hover .loader-grid,
  .loader-container[data-loader-animation="true"]:hover .loader-spotlight,
  .loader-container[data-loader-animation="true"]:hover .loader-icon,
  .loader-container[data-loader-animation="true"]:hover .loader-sweep {
    animation: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .loader-sweep {
      animation: none !important;
      opacity: 0.5 !important;
    }
  }

  @keyframes sweep-back-and-forth {
    0%,
    100% {
      -webkit-mask-position: 150% 0;
      mask-position: 150% 0;
    }
    50% {
      -webkit-mask-position: -50% 0;
      mask-position: -50% 0;
    }
  }

  @keyframes grid-nebula-drift {
    0% {
      background-position:
        0 0,
        center;
    }
    50% {
      background-position:
        26px 14px,
        center;
    }
    100% {
      background-position:
        0 0,
        center;
    }
  }

  @keyframes spotlight-breathe {
    0%,
    100% {
      opacity: 0.78;
      transform: scale(1);
    }
    50% {
      opacity: 0.98;
      transform: scale(1.06);
    }
  }

  @keyframes icon-levitate {
    0%,
    100% {
      transform: translateY(0) scale(1);
      filter: drop-shadow(0 0 0 transparent);
    }
    50% {
      transform: translateY(-3px) scale(1.04);
      filter: drop-shadow(
        0 0 6px color-mix(in srgb, var(--accent) 45%, transparent)
      );
    }
  }

  @media (hover: none), (pointer: coarse) {
    .loader-container[data-loader-spotlight="hover"] .loader-spotlight {
      opacity: 0.86;
    }
  }

  .loader-edge {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 300ms ease;
    background-image: radial-gradient(
      circle,
      var(--loader-highlight-color) calc(var(--loader-dot-size) * 1.5),
      transparent var(--loader-highlight-blur)
    );
    background-position: 0 0;
    background-size: var(--loader-grid-size) var(--loader-grid-size);
    /* Highlight all edges creating a deeply layered 3D depth bounding box */
    --mask-x: linear-gradient(
      to right,
      #000 0%,
      rgba(0, 0, 0, 0.9) calc(var(--loader-grid-size) * 1),
      rgba(0, 0, 0, 0.75) calc(var(--loader-grid-size) * 2),
      rgba(0, 0, 0, 0.5) calc(var(--loader-grid-size) * 3),
      rgba(0, 0, 0, 0.3) calc(var(--loader-grid-size) * 4),
      rgba(0, 0, 0, 0.15) calc(var(--loader-grid-size) * 5),
      transparent calc(var(--loader-grid-size) * 6),
      transparent calc(100% - calc(var(--loader-grid-size) * 6)),
      rgba(0, 0, 0, 0.15) calc(100% - calc(var(--loader-grid-size) * 5)),
      rgba(0, 0, 0, 0.3) calc(100% - calc(var(--loader-grid-size) * 4)),
      rgba(0, 0, 0, 0.5) calc(100% - calc(var(--loader-grid-size) * 3)),
      rgba(0, 0, 0, 0.75) calc(100% - calc(var(--loader-grid-size) * 2)),
      rgba(0, 0, 0, 0.9) calc(100% - calc(var(--loader-grid-size) * 1)),
      #000 100%
    );
    --mask-y: linear-gradient(
      to bottom,
      #000 0%,
      rgba(0, 0, 0, 0.9) calc(var(--loader-grid-size) * 1),
      rgba(0, 0, 0, 0.75) calc(var(--loader-grid-size) * 2),
      rgba(0, 0, 0, 0.5) calc(var(--loader-grid-size) * 3),
      rgba(0, 0, 0, 0.3) calc(var(--loader-grid-size) * 4),
      rgba(0, 0, 0, 0.15) calc(var(--loader-grid-size) * 5),
      transparent calc(var(--loader-grid-size) * 6),
      transparent calc(100% - calc(var(--loader-grid-size) * 6)),
      rgba(0, 0, 0, 0.15) calc(100% - calc(var(--loader-grid-size) * 5)),
      rgba(0, 0, 0, 0.3) calc(100% - calc(var(--loader-grid-size) * 4)),
      rgba(0, 0, 0, 0.5) calc(100% - calc(var(--loader-grid-size) * 3)),
      rgba(0, 0, 0, 0.75) calc(100% - calc(var(--loader-grid-size) * 2)),
      rgba(0, 0, 0, 0.9) calc(100% - calc(var(--loader-grid-size) * 1)),
      #000 100%
    );
    -webkit-mask-image: var(--mask-x), var(--mask-y);
    mask-image: var(--mask-x), var(--mask-y);
  }

  @media (hover: hover) and (pointer: fine) {
    .loader-container[data-loader-edge="true"]:hover .loader-edge {
      opacity: 0.9;
    }
  }

  .loader-icon :global(svg) {
    width: clamp(2rem, 15cqw, 4rem);
    height: clamp(2rem, 15cqw, 4rem);
    color: inherit;
  }

  .loader-icon :global(.pacman-spinner-nadzu),
  .loader-icon :global(.pacmanloadernuu-open),
  .loader-icon :global(.pacmanloadernuu-mouth-top),
  .loader-icon :global(.pacmanloadernuu-mouth-bottom) {
    fill: currentColor;
  }

  @container (min-width: 150px) and (min-height: 80px) {
    .loader-icon {
      display: grid;
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .loader-container[data-loader-content="true"]:hover .loader-icon {
      opacity: 1;
    }
    .loader-container[data-loader-content="true"]:hover .loader-grid {
      opacity: 0.25;
    }
    .loader-container[data-loader-content="true"]:hover .loader-sweep {
      opacity: 0.35;
    }
  }

  @keyframes loader-message-in {
    to {
      clip-path: inset(0 0 0 0);
      opacity: 1;
    }
  }

  @keyframes loader-message-out {
    from {
      clip-path: inset(0 0 0 0);
      opacity: 1;
    }

    to {
      clip-path: inset(0 100% 0 0);
      opacity: 0;
    }
  }
</style>

<script>
  type LoaderSpotlightMode = "hover" | "always" | "none";

  let isUpdating = false;
  let skeletonElements: HTMLElement[] = [];

  const refreshSkeletonElements = () => {
    skeletonElements = Array.from(
      document.querySelectorAll(
        '.loader-container[data-loader-skeleton="true"]'
      )
    ) as HTMLElement[];
  };

  const updateSkeletonOffsets = () => {
    if (isUpdating || skeletonElements.length === 0) return;
    isUpdating = true;

    requestAnimationFrame(() => {
      for (let i = 0; i < skeletonElements.length; i++) {
        const el = skeletonElements[i];
        const rect = el.getBoundingClientRect();
        el.style.setProperty("--bg-x", `${-rect.left}px`);
        el.style.setProperty("--bg-y", `${-rect.top}px`);
      }
      isUpdating = false;
    });
  };

  if (typeof window !== "undefined") {
    const loaderGlobal = window as typeof window & {
      __loaderSkeletonEventsBound?: boolean;
    };

    if (!loaderGlobal.__loaderSkeletonEventsBound) {
      window.addEventListener("scroll", updateSkeletonOffsets, {
        passive: true,
      });
      window.addEventListener("resize", updateSkeletonOffsets, {
        passive: true,
      });
      loaderGlobal.__loaderSkeletonEventsBound = true;
    }
  }

  class LoaderManager {
    private loader: HTMLElement | null;
    private fadeOutClass = "fade-out";
    private revealDuration = 420;

    constructor(loaderElement: HTMLElement) {
      this.loader = loaderElement;
    }

    hide(): Promise<void> {
      return new Promise(resolve => {
        if (!this.loader) {
          resolve();
          return;
        }

        const element = this.loader;
        element.dataset.loaderState = "exit";
        const fallbackTimeout = this.revealDuration + 120;

        let resolved = false;
        const cleanup = () => {
          if (!resolved) {
            resolved = true;
            element.removeEventListener("transitionend", onTransitionEnd);
            if (this.loader) {
              this.loader.style.display = "none";
            }
            resolve();
          }
        };

        const onTransitionEnd = (e: TransitionEvent) => {
          if (e.target === element && e.propertyName === "opacity") {
            cleanup();
          }
        };

        element.addEventListener("transitionend", onTransitionEnd);
        element.classList.add(this.fadeOutClass);

        // Fallback in case transitionend doesn't fire
        setTimeout(cleanup, fallbackTimeout + 100);
      });
    }

    show(): void {
      if (!this.loader) return;

      this.loader.style.display = "";
      this.loader.classList.remove(this.fadeOutClass);
      this.loader.dataset.loaderState = "enter";
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          if (this.loader) {
            this.loader.dataset.loaderState = "ready";
          }
        });
      });
    }

    remove(): void {
      this.hide().then(() => {
        if (this.loader && this.loader.parentNode) {
          this.loader.parentNode.removeChild(this.loader);
        }
      });
    }
  }

  class LoaderSpotlight {
    private loader: HTMLElement;
    private mode: LoaderSpotlightMode;
    private isPointerFine: boolean;
    private loaderRect: DOMRect | null = null;
    private rafId: number | null = null;
    private queuedEvent: PointerEvent | null = null;
    private readonly onWindowResize = () => {
      this.loaderRect = null;
    };

    constructor(loaderElement: HTMLElement, mode: LoaderSpotlightMode) {
      this.loader = loaderElement;
      this.mode = mode;
      this.isPointerFine = window.matchMedia(
        "(hover: hover) and (pointer: fine)"
      ).matches;
    }

    private isBackgroundLoader(): boolean {
      return this.loader.classList.contains("loader-container--background");
    }

    private shouldDisableBackgroundSpotlight(): boolean {
      if (!this.isBackgroundLoader()) return false;

      const nav = navigator as Navigator & {
        connection?: { saveData?: boolean };
      };
      const saveData = nav.connection?.saveData === true;
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;
      const isCoarsePointer = window.matchMedia(
        "(hover: none), (pointer: coarse)"
      ).matches;
      const lowCpuCores =
        typeof navigator.hardwareConcurrency === "number" &&
        navigator.hardwareConcurrency > 0 &&
        navigator.hardwareConcurrency <= 4;

      // Disable always-on background spotlight in power-constrained contexts.
      return saveData || prefersReducedMotion || isCoarsePointer || lowCpuCores;
    }

    private clearSpotlightPosition(): void {
      this.loader.style.removeProperty("--loader-spotlight-x");
      this.loader.style.removeProperty("--loader-spotlight-y");
      this.loader.style.removeProperty("--loader-spotlight-size");
    }

    init(): void {
      if (this.shouldDisableBackgroundSpotlight()) {
        this.clearSpotlightPosition();
        this.loader.classList.remove("loader-spotlight-active");
        return;
      }

      if (this.mode === "none") {
        this.clearSpotlightPosition();
        return;
      }

      if (this.mode === "always" || !this.isPointerFine) {
        this.setSpotlightToCenter();
        this.loader.classList.add("loader-spotlight-active");
        return;
      }

      this.setSpotlightToCenter();
      this.loader.classList.add("loader-spotlight-active");
      this.attachHoverListeners();
    }

    private attachHoverListeners(): void {
      const isGlobal = this.loader.dataset.loaderGlobalHover === "true";
      const target = isGlobal ? document.documentElement : this.loader;
      const shouldTrackScroll = !isGlobal && !this.isBackgroundLoader();

      const onEnter = (event: Event) => {
        this.loader.classList.add("loader-spotlight-active");
        this.updateFromPointer(event as PointerEvent);
      };

      const onMove = (event: Event) => {
        this.queuePointerUpdate(event as PointerEvent);
      };

      const onLeave = () => {
        this.setSpotlightToCenter();
      };

      if (isGlobal) {
        this.loader.classList.add("loader-spotlight-active");
        target.addEventListener("pointermove", onMove as EventListener);
      } else {
        target.addEventListener("pointerenter", onEnter as EventListener);
        target.addEventListener("pointermove", onMove as EventListener);
        target.addEventListener("pointerleave", onLeave as EventListener);
      }

      window.addEventListener("resize", this.onWindowResize, { passive: true });
      if (shouldTrackScroll) {
        window.addEventListener("scroll", this.onWindowResize, {
          passive: true,
        });
      }
    }

    private queuePointerUpdate(event: PointerEvent): void {
      this.queuedEvent = event;
      if (this.rafId !== null) return;

      this.rafId = requestAnimationFrame(() => {
        this.rafId = null;
        if (this.queuedEvent) {
          this.updateFromPointer(this.queuedEvent);
          this.queuedEvent = null;
        }
      });
    }

    private getLoaderRect(): DOMRect {
      if (!this.loaderRect) {
        this.loaderRect = this.loader.getBoundingClientRect();
      }

      return this.loaderRect;
    }

    private updateFromPointer(event: PointerEvent): void {
      const rect = this.getLoaderRect();
      const x = ((event.clientX - rect.left) / rect.width) * 100;
      const y = ((event.clientY - rect.top) / rect.height) * 100;

      this.loader.style.setProperty(
        "--loader-spotlight-x",
        `${Math.min(100, Math.max(0, x))}%`
      );
      this.loader.style.setProperty(
        "--loader-spotlight-y",
        `${Math.min(100, Math.max(0, y))}%`
      );
      this.loader.style.setProperty(
        "--loader-spotlight-size",
        `${Math.max(110, Math.min(rect.width, rect.height) * 0.35)}px`
      );
    }

    private setSpotlightToCenter(): void {
      // Keep a fixed top-left anchor on small screens for visual stability.
      const isMobile = window.innerWidth < 768;

      this.loader.style.setProperty(
        "--loader-spotlight-x",
        isMobile ? "0%" : "50%"
      );
      this.loader.style.setProperty(
        "--loader-spotlight-y",
        isMobile ? "0%" : "50%"
      );
      this.loader.style.setProperty(
        "--loader-spotlight-size",
        isMobile ? "120px" : "180px"
      );
    }
  }

  if (typeof window !== "undefined") {
    window.LoaderManager = LoaderManager;
  }

  const initLoaders = () => {
    refreshSkeletonElements();

    const loaders = document.querySelectorAll("[data-loader]");
    loaders.forEach(loader => {
      const element = loader as HTMLElement;
      if (element.dataset.loaderInitialized === "true") {
        return;
      }

      element.dataset.loaderInitialized = "true";
      const manager = new LoaderManager(element);
      element.__loaderManager = manager;

      const spotlightMode = (element.dataset.loaderSpotlight ||
        "hover") as LoaderSpotlightMode;
      const spotlight = new LoaderSpotlight(element, spotlightMode);
      spotlight.init();

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          if (element.dataset.loaderState === "enter") {
            element.dataset.loaderState = "ready";
          }
        });
      });
    });

    updateSkeletonOffsets();
  };

  initLoaders();
  document.addEventListener("astro:page-load", initLoaders);
</script>
