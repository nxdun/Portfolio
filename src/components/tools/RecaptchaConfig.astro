---
import { RECAPTCHA_SITE_KEY } from "astro:env/server";
import { BACKEND_SERVER_URL } from "astro:env/server";

const recaptchaSiteKey = (RECAPTCHA_SITE_KEY ?? "").trim();
const toolsBackendUrl = (BACKEND_SERVER_URL ?? "").trim();
---

<div
  id="tool-captcha-config"
  class="hidden"
  aria-hidden="true"
  data-recaptcha-site-key={recaptchaSiteKey}
  data-ytdlp-backend-url={toolsBackendUrl}
>
</div>
