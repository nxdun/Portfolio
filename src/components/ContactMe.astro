---
import { RECAPTCHA_SITE_KEY } from "astro:env/server";
---

<section id="contact-me" class="pt-12 pb-6">
  <div class="mx-auto flex flex-col items-center gap-6 lg:w-2/3">
    <h2 id="contact-me-heading" class="mb-4 text-3xl font-bold tracking-wide">
      Let's Discuss Your Infrastructure.
    </h2>

    <div id="contact-response-host" class="hidden w-full"></div>

    <form
      id="contact-form"
      class="flex w-full flex-col gap-5"
      data-site-key={RECAPTCHA_SITE_KEY}
    >
      <div>
        <label for="name" class="mb-1 block text-sm font-medium text-foreground"
          >Name</label
        >
        <input
          type="text"
          name="name"
          id="contact-name"
          required
          placeholder="Your Name or Company"
          class="w-full rounded-lg border border-border bg-muted/10 px-4 py-2 focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none"
        />
      </div>

      <div>
        <label
          for="email"
          class="mb-1 block text-sm font-medium text-foreground">Email</label
        >
        <input
          type="email"
          name="email"
          id="contact-email"
          required
          placeholder="your.email@example.com"
          class="w-full rounded-lg border border-border bg-muted/10 px-4 py-2 focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none"
        />
      </div>

      <div>
        <label
          for="purpose"
          class="mb-1 block text-sm font-medium text-foreground"
          >Inquiry Type</label
        >
        <input
          type="text"
          name="purpose"
          id="contact-purpose"
          required
          placeholder="e.g., Cloud Architecture, Freelance Project, Job Offer"
          class="w-full rounded-lg border border-border bg-muted/10 px-4 py-2 focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none"
        />
      </div>

      <div>
        <label
          for="message"
          class="mb-1 block text-sm font-medium text-foreground">Message</label
        >
        <textarea
          name="message"
          id="contact-message"
          rows="5"
          required
          placeholder="Tell me about your project, current bottlenecks, or team needs..."
          class="w-full rounded-lg border border-border bg-muted/10 px-4 py-2 focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none"
        ></textarea>
      </div>

      <div class="mt-4 flex justify-center">
        <button
          type="submit"
          class="flex w-full items-center justify-center rounded-lg bg-accent px-8 py-3 text-sm font-bold text-background transition-colors hover:bg-accent/90 focus:ring-4 focus:ring-accent/50 sm:w-auto"
        >
          Send Inquiry
        </button>
      </div>
    </form>
  </div>
</section>

<script>
  import { actions } from "astro:actions";
  import type { ToolResponseDock } from "@/scripts/tools/ui/responseDock";
  import type { CaptchaDialogController } from "@/scripts/tools/ui/captchaDialog";
  import type { CaptchaManager } from "@/utils/captchaManager";

  const initContactForm = () => {
    const form = document.getElementById(
      "contact-form"
    ) as HTMLFormElement | null;
    const responseHost = document.getElementById("contact-response-host");

    if (!form || !responseHost) return;

    let responseDock: ToolResponseDock | null = null;

    const submitButton = form.querySelector(
      'button[type="submit"]'
    ) as HTMLButtonElement | null;
    if (!submitButton) return;

    let captchaManager: CaptchaManager | null = null;
    let captchaDialog: CaptchaDialogController | null = null;
    const siteKey = form.getAttribute("data-site-key");

    let depsPromise: Promise<void> | null = null;

    const loadDependencies = () => {
      if (!depsPromise) {
        const promises: Promise<unknown>[] = [
          import("@/scripts/tools/ui/responseDock").then(
            ({ createToolResponseDock }) => {
              responseDock = createToolResponseDock(responseHost, {
                title: "Contact Status",
                hiddenOnIdle: true,
              });
            }
          ),
        ];

        if (siteKey) {
          promises.push(
            Promise.all([
              import("@/scripts/tools/ui/captchaDialog"),
              import("@/utils/captchaManager"),
            ]).then(([{ createCaptchaDialog }, { CaptchaManager }]) => {
              captchaDialog = createCaptchaDialog(document.body, {
                idPrefix: "contact",
              });

              if (captchaDialog) {
                captchaManager = new CaptchaManager({
                  host: captchaDialog.refs.captchaHostEl,
                  siteKey: siteKey,
                  onSolved: () => {
                    if (captchaDialog) {
                      captchaDialog.refs.verifyBtn.disabled = false;
                    }
                  },
                });
                captchaManager.ensureReady().catch(() => {});
              }
            })
          );
        }

        depsPromise = Promise.all(promises).then(() => {});
      }
      return depsPromise;
    };

    // Preload lazy dependencies on first form interaction
    form.addEventListener(
      "input",
      () => {
        loadDependencies();
      },
      { once: true }
    );

    form.addEventListener("submit", async e => {
      e.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      await loadDependencies();

      const formData = new FormData(form);

      const executeForm = async (captchaToken?: string) => {
        submitButton!.disabled = true;
        responseDock?.setState("pending", "Sending your message...");

        if (captchaToken) {
          formData.append("g-recaptcha-response", captchaToken);
        }

        try {
          const result = await actions.contact(formData);

          if (result.error) {
            throw new Error(result.error.message);
          }

          const formElements = form.querySelectorAll("input, textarea, button");
          formElements.forEach(el => {
            (el as HTMLInputElement).disabled = true;
          });

          responseDock?.setState(
            "success",
            `Thanks for reaching out, ${result.data?.name || "there"}! I'll get back to you within 24-48 hours.`
          );
        } catch (err) {
          // eslint-disable-next-line no-console
          console.error(err);
          responseDock?.setState(
            "fail",
            "Something went wrong on my end. Please email me directly at hello@nadzu.me"
          );
          submitButton!.disabled = false;
        }
      };

      if (captchaManager && captchaDialog) {
        captchaManager.ensureRendered().catch(() => {});
        captchaManager.reset();
        captchaDialog.refs.verifyBtn.disabled = true;
        const verifyBtnHtml = captchaDialog.refs.verifyBtn;

        captchaDialog.open();

        const onVerifyClick = async () => {
          const token = captchaManager!.getToken();
          if (!token) return;

          verifyBtnHtml.disabled = true;
          verifyBtnHtml.onclick = null;

          await executeForm(token);

          // Close dialog only after submission completes
          captchaDialog!.close();
        };

        verifyBtnHtml.onclick = null;
        verifyBtnHtml.onclick = onVerifyClick;
      } else {
        executeForm();
      }
    });
  };

  document.addEventListener("astro:page-load", initContactForm);
</script>
