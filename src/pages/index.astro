---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Loader from "@/components/Loader.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import ContactMe from "@/components/ContactMe.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getFeaturedProjects } from "@/utils/projectUtils";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const featuredProjects = getFeaturedProjects(3);
const emptyFeaturedProjectCount = Math.max(0, 3 - featuredProjects.length);

const backendUrl = import.meta.env.PUBLIC_TOOLS_BACKEND_URL;
const contributionsUrl = backendUrl
  ? `${backendUrl.replace(/\/+$/, "")}/api/v1/contributions`
  : null;
---

<Layout>
  {
    contributionsUrl && (
      <link
        rel="preload"
        href={contributionsUrl}
        as="fetch"
        crossorigin
        media="(min-width:1280px)"
        slot="head"
      />
    )
  }
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Building Scalable Clouds & Code That Ships
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <h2 class="mb-4 text-xl font-medium sm:text-2xl">
        I am <span id="dynamic-text" class="font-bold text-accent"
          >a Student</span
        ><span id="cursor" class="animate-pulse">|</span>
      </h2>

      <p class="leading-relaxed tracking-wide">
        Graduating Software Engineer with a{" "}
        <span class="font-medium">DevOps mindset</span>. I bridge the gap
        between complex infrastructure and clean application code using
        <span class="font-medium">AWS</span> and{" "}
        <span class="font-medium">modern CI/CD</span>. Ready to deploy
        production-grade solutions.
      </p>

      <div
        class="mt-6 flex flex-col items-stretch justify-between gap-12 xl:flex-row xl:gap-8"
      >
        <div class="flex flex-col gap-4">
          <LinkButton href="/posts/" class="whitespace-nowrap">
            All Posts
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>

          <LinkButton href="/projects/" class="whitespace-nowrap">
            All Projects
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>

          <LinkButton href="/tools?tool=base64" class="whitespace-nowrap">
            All Tools
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>

          {
            // only display if at least one social link is enabled
            SOCIALS.length > 0 && (
              <div class="mt-4 flex max-sm:flex-col sm:items-center">
                <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
                  Social Links:
                </div>
                <div class="flex items-center">
                  <Socials />
                  <div class="pointer-events-none hidden opacity-30 select-none xl:block">
                    <svg
                      width="50"
                      height="20"
                      viewBox="0 0 50 20"
                      fill="none"
                      class="animate-pulse-horizontal ms-4 -rotate-10"
                    >
                      <path
                        d="M2 5C10 12 30 12 45 6"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                      />
                      <path
                        d="M38 7L45 6L40 13"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </div>
                </div>
              </div>
            )
          }
        </div>

        <div
          class="relative hidden w-full flex-1 items-center overflow-hidden align-middle xl:flex"
        >
          <div
            class="hero-contribution-shell h-full min-h-40 w-full"
            data-contribution-graph
            data-contribution-graph-state="loading"
            aria-label="GitHub contribution activity"
          >
            <section class="hero-contribution-surface">
              <div class="hero-contribution-head" aria-hidden="true">
                <div class="hero-contribution-months" data-contribution-months>
                </div>
              </div>
              <div class="hero-contribution-body">
                <div
                  class="hero-contribution-weekdays"
                  data-contribution-weekdays
                >
                </div>
                <div class="hero-contribution-grid-wrap">
                  <div
                    class="hero-contribution-grid"
                    data-contribution-grid
                    role="grid"
                    aria-label="GitHub contribution graph"
                  >
                  </div>
                </div>
              </div>
              <div class="hero-contribution-foot">
                <div
                  class="hero-contribution-summary"
                  data-contribution-summary
                >
                </div>
                <div class="hero-contribution-legend" data-contribution-legend>
                </div>
              </div>
              <div class="hero-contribution-tooltip" data-contribution-tooltip>
              </div>
              <p
                class="hero-contribution-status"
                data-contribution-status
                aria-live="polite"
                aria-atomic="true"
              >
              </p>
            </section>
          </div>
        </div>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/" class="whitespace-nowrap">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>

    {
      featuredProjects.length > 0 && (
        <section id="projects" class="border-t border-border pt-12 pb-6">
          <h2 class="mb-4 text-2xl font-semibold tracking-wide">
            Featured Projects
          </h2>
          <ul class="mt-2 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
            {featuredProjects.map(project => (
              <ProjectCard variant="h3" project={project} />
            ))}
            {Array.from({ length: emptyFeaturedProjectCount }).map(() => (
              <li class="hidden h-full flex-col rounded-xl md:flex">
                <Loader
                  mode="attached"
                  isSkeleton={true}
                  content="All Projects →"
                  contentHref="/projects/"
                  class="h-full min-h-70 w-full rounded-2xl"
                  animation={false}
                  spotlight="hover"
                  sweep={true}
                  edgeHighlight={true}
                />
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/projects/">
        All Projects
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>

    <ContactMe />
  </main>
  <Footer />
</Layout>

<script>
  import { startTypingAnimation } from "@/utils/typingAnimation";

  const initHomePage = () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }

    startTypingAnimation("dynamic-text", [
      "a DevOps Engineer",
      "a Software Engineer",
      "a Cloud Architect",
    ]);

    // Break the critical dependency chain for the contribution graph.
    // By using a dynamic import, we defer the loading of the graph logic
    // and its dependencies (like types) until after the main page is ready.
    // We only initialize it on large screens (>=1280px) to match preload behavior.
    const isLargeScreen = window.matchMedia("(min-width: 1280px)").matches;
    if (isLargeScreen && document.querySelector("[data-contribution-graph]")) {
      const initGraph = async () => {
        const { initContributionGraph } =
          await import("@/scripts/contributionGraph");
        initContributionGraph();
      };

      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(initGraph);
      } else {
        setTimeout(initGraph, 200);
      }
    }
  };

  initHomePage();
  document.addEventListener("astro:page-load", initHomePage);
</script>

<style>
  @keyframes pulse-horizontal {
    0%,
    100% {
      transform: translateX(0) rotate(-10deg);
    }
    50% {
      transform: translateX(4px) rotate(-10deg);
    }
  }
  .animate-pulse-horizontal {
    animation: pulse-horizontal 3s infinite ease-in-out;
  }
</style>
