---
// --- Framework ---
import { getCollection } from "astro:content";

// --- Layouts ---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/core/Header.astro";
import Footer from "@/components/core/Footer.astro";

// --- Components (Above-Fold) ---
import Socials from "@/components/ui/Socials.astro";
import LinkButton from "@/components/ui/LinkButton.astro";

// --- Components (Below-Fold) ---
import Card from "@/components/ui/Card.astro";
import ProjectCard from "@/features/projects/components/ProjectCard.astro";
import ContactMe from "@/features/contact-form/components/ContactMe.astro";
import Loader from "@/components/core/Loader.astro";

// --- Utilities & Config ---
import { getSortedPosts } from "@/features/blog";
import { getFeaturedProjects } from "@/features/projects";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

// --- Data: Blogs ---
const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

// --- Data: Projects ---
const featuredProjects = getFeaturedProjects(3);
const emptyFeaturedProjectCount = Math.max(0, 3 - featuredProjects.length);

// --- Config: Environment & APIs ---
const backendUrl = import.meta.env.BACKEND_SERVER_URL;
const contributionsUrl = backendUrl
  ? `${backendUrl.replace(/\/+$/, "")}/api/v1/contributions`
  : null;
---

<Layout>
  {/* --- Head: Resource Hints --- */}
  {
    contributionsUrl && (
      <link
        rel="preload"
        href={contributionsUrl}
        as="fetch"
        crossorigin
        fetchpriority="low"
        media="(min-width:1280px)"
        slot="head"
      />
    )
  }

  <Header />

  <main id="main-content" data-layout="index" class="app-layout">
    {/* --- Hero Section --- */}
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Software breaks. Well-architected systems endure.
      </h1>

      <h2 class="mb-4 text-xl font-medium sm:text-2xl">
        I am <span id="dynamic-text" class="font-bold text-accent"
          >DevOps Engineer</span
        ><span id="cursor" class="animate-pulse">|</span>
      </h2>

      <p class="leading-relaxed tracking-wide">
        Great software is more than code; it is the entire lifecycle. Security
        is the baseline, automation drives delivery. Testing guarantees
        precision. Infrastructure is the backbone. When these components are
        integrated, complete software systems are built.
      </p>

      <div
        class="mt-6 flex flex-col items-stretch justify-between gap-12 xl:flex-row xl:gap-8"
      >
        <div class="flex flex-col gap-4">
          <LinkButton href="/posts/" class="whitespace-nowrap">
            Read My Blogs
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>

          <LinkButton href="/projects/" class="whitespace-nowrap">
            My Works
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>

          <LinkButton href="/tools?tool=base64" class="whitespace-nowrap">
            Online Tools
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>

          {
            SOCIALS.length > 0 && (
              <div class="mt-4 flex max-sm:flex-col sm:items-center">
                <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Connect:</div>
                <div class="flex items-center">
                  <Socials />
                  <div class="pointer-events-none hidden opacity-30 select-none xl:block">
                    <svg
                      width="50"
                      height="20"
                      viewBox="0 0 50 20"
                      fill="none"
                      class="animate-pulse-horizontal ms-4 -rotate-10"
                      aria-hidden="true"
                    >
                      <path
                        d="M2 5C10 12 30 12 45 6"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                      />
                      <path
                        d="M38 7L45 6L40 13"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </div>
                </div>
              </div>
            )
          }
        </div>

        {/* --- Hero: Contribution Graph --- */}
        <div
          class="relative hidden w-full flex-1 items-center overflow-hidden align-middle xl:flex"
        >
          <div
            class="hero-contribution-shell h-full min-h-40 w-full"
            data-contribution-graph
            data-contribution-graph-url={backendUrl}
            data-contribution-graph-state="loading"
            aria-label="GitHub contribution activity"
          >
            <section class="hero-contribution-surface">
              <div class="hero-contribution-head" aria-hidden="true">
                <div class="hero-contribution-months" data-contribution-months>
                </div>
              </div>
              <div class="hero-contribution-body">
                <div
                  class="hero-contribution-weekdays"
                  data-contribution-weekdays
                >
                </div>
                <div class="hero-contribution-grid-wrap">
                  <div
                    class="hero-contribution-grid"
                    data-contribution-grid
                    role="grid"
                    aria-label="GitHub contribution graph"
                  >
                  </div>
                </div>
              </div>
              <div class="hero-contribution-foot">
                <div
                  class="hero-contribution-summary"
                  data-contribution-summary
                >
                </div>
                <div class="hero-contribution-legend" data-contribution-legend>
                </div>
              </div>
              <div class="hero-contribution-tooltip" data-contribution-tooltip>
              </div>
              <p
                class="hero-contribution-status"
                data-contribution-status
                aria-live="polite"
                aria-atomic="true"
              >
              </p>
            </section>
          </div>
        </div>
      </div>
    </section>

    {/* --- Featured Blogs --- */}
    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured Blogs</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {/* --- Recent Blogs --- */}
    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Latest Blogs</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/" class="whitespace-nowrap">
        View all Blogs
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>

    {/* --- Projects --- */}
    {
      featuredProjects.length > 0 && (
        <section id="projects" class="border-t border-border pt-12 pb-6">
          <h2 class="mb-4 text-2xl font-semibold tracking-wide">
            Projects I've Built
          </h2>
          <ul class="mt-2 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
            {featuredProjects.map(project => (
              <ProjectCard variant="h3" project={project} />
            ))}
            {Array.from({ length: emptyFeaturedProjectCount }).map(() => (
              <li class="hidden h-full flex-col rounded-xl md:flex">
                <Loader
                  mode="attached"
                  isSkeleton={true}
                  content="View all Projects →"
                  contentHref="/projects/"
                  class="h-full min-h-70 w-full rounded-2xl"
                  spotlight="hover"
                  sweep={true}
                  edgeHighlight={true}
                />
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/projects/">
        View all Projects
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>

    {/* --- Contact --- */}
    <ContactMe />
  </main>

  <Footer />
</Layout>

<script src="../scripts/home.ts"></script>
