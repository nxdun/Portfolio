---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/core/Header.astro";
import Footer from "@/components/core/Footer.astro";
import { BACKEND_SERVER_URL } from "astro:env/server";

const apiUrl = `${BACKEND_SERVER_URL}/api/v1/malee`;
---

<Layout title="Malee Agent Debug | ~/nadzu" useBackendApi={true}>
  <Header activeNav={undefined} />
  <main
    id="malee-debug-root"
    data-api-url={apiUrl}
    class="mx-auto flex w-full max-w-[1800px] flex-col items-start gap-6 px-4 py-6 sm:px-8 lg:flex-row"
  >
    <!-- Left column: Chat Interface -->
    <div
      class="flex h-[calc(100vh-140px)] max-h-[850px] w-full min-w-0 flex-1 flex-col overflow-hidden rounded-2xl border border-border/70 bg-background"
    >
      <!-- Header Bar -->
      <div
        class="flex shrink-0 items-center justify-between border-b border-border/70 bg-muted/10 p-4"
      >
        <div>
          <h1 class="text-lg font-bold">Malee Debug Console</h1>
          <p class="mt-0.5 flex items-center gap-2 text-xs opacity-70">
            <span class="font-mono">{apiUrl}</span>
            <span
              id="status-dot"
              class="mt-0.5 inline-block h-2.5 w-2.5 shrink-0 rounded-full bg-red-500"
            ></span>
            <span id="session-id-display" class="font-medium"
              >No active session</span
            >
          </p>
        </div>
        <div class="flex shrink-0 items-center gap-2">
          <button
            id="btn-clear-chat"
            class="rounded-lg border border-border/70 px-3 py-1.5 text-xs font-semibold transition-colors hover:bg-muted/20"
          >
            Clear Chat
          </button>
          <button
            id="btn-new-session"
            class="rounded-lg bg-accent px-3 py-1.5 text-xs font-semibold text-background transition-opacity hover:opacity-90"
          >
            New Session
          </button>
        </div>
      </div>

      <!-- Chat Messages -->
      <div
        id="chat-messages"
        class="relative flex flex-1 flex-col gap-2 overflow-y-auto scroll-smooth p-4"
      >
        <div
          id="chat-empty-state"
          class="flex h-full items-center justify-center text-sm italic opacity-50"
        >
          Start chatting
        </div>
      </div>

      <!-- Input Bar -->
      <div
        class="flex shrink-0 items-center gap-3 border-t border-border/70 bg-muted/10 p-4"
      >
        <select
          id="chat-lang-select"
          class="rounded-lg border border-border/70 bg-background px-2 py-2 text-xs focus:border-accent focus:outline-none"
        >
          <option value="auto">Auto</option>
          <option value="english">English</option>
          <option value="sinhala">Sinhala</option>
          <option value="mixed">Mixed</option>
        </select>

        <input
          id="chat-input"
          type="text"
          placeholder="Type your message..."
          class="flex-1 rounded-lg border border-border/70 bg-background px-4 py-2 text-sm focus:border-accent focus:outline-none"
          autocomplete="off"
        />

        <button
          id="chat-send-btn"
          class="rounded-lg bg-accent px-5 py-2 text-sm font-semibold text-background transition-opacity hover:opacity-90 disabled:opacity-50"
        >
          Send
        </button>
      </div>
    </div>

    <!-- Right column: Debug Panel -->
    <div
      class="flex w-full shrink-0 flex-col gap-4 lg:w-[360px] xl:w-[420px] 2xl:w-[500px]"
    >
      <!-- Session State -->
      <div
        id="panel-session"
        class="debug-panel-section overflow-hidden rounded-2xl border border-border/70 bg-background"
      >
        <div
          class="section-header flex cursor-pointer items-center justify-between border-b border-border/50 bg-muted/5 p-3 transition-colors hover:bg-muted/10"
        >
          <span class="text-xs font-semibold tracking-wide uppercase opacity-80"
            >Session State</span
          >
          <span class="section-icon text-xs opacity-60">▼</span>
        </div>
        <div id="panel-session-content" class="section-content p-4">
          <div class="py-2 text-sm italic opacity-50">
            Waiting for session...
          </div>
        </div>
      </div>

      <!-- Cart -->
      <div
        id="panel-cart"
        class="debug-panel-section overflow-hidden rounded-2xl border border-border/70 bg-background"
      >
        <div
          class="section-header flex cursor-pointer items-center justify-between border-b border-border/50 bg-muted/5 p-3 transition-colors hover:bg-muted/10"
        >
          <span class="text-xs font-semibold tracking-wide uppercase opacity-80"
            >Cart</span
          >
          <span class="section-icon text-xs opacity-60">▼</span>
        </div>
        <div id="panel-cart-content" class="section-content p-4">
          <div class="py-2 text-sm italic opacity-50">Cart is empty</div>
        </div>
      </div>

      <!-- Profile -->
      <div
        id="panel-profile"
        class="debug-panel-section overflow-hidden rounded-2xl border border-border/70 bg-background"
      >
        <div
          class="section-header flex cursor-pointer items-center justify-between border-b border-border/50 bg-muted/5 p-3 transition-colors hover:bg-muted/10"
        >
          <span class="text-xs font-semibold tracking-wide uppercase opacity-80"
            >User Profile</span
          >
          <span class="section-icon text-xs opacity-60">▼</span>
        </div>
        <div id="panel-profile-content" class="section-content p-4">
          <div class="py-2 text-sm italic opacity-50">Profile not loaded</div>
        </div>
      </div>

      <!-- SSE Event Log -->
      <div
        id="panel-log"
        class="debug-panel-section flex max-h-[400px] flex-1 flex-col overflow-hidden rounded-2xl border border-border/70 bg-background"
      >
        <div
          class="section-header flex cursor-pointer items-center justify-between border-b border-border/50 bg-muted/5 p-3 transition-colors hover:bg-muted/10"
        >
          <div class="flex items-center gap-3">
            <span
              class="text-xs font-semibold tracking-wide uppercase opacity-80"
              >SSE Event Log</span
            >
            <button
              id="btn-clear-log"
              class="rounded bg-border/50 px-2 py-0.5 text-[10px] transition-colors hover:bg-border/80"
              onclick="event.stopPropagation()">Clear Log</button
            >
          </div>
          <span class="section-icon text-xs opacity-60">▼</span>
        </div>
        <div
          id="panel-log-content"
          class="section-content flex-1 overflow-y-auto bg-black/5 p-3 dark:bg-black/20"
        >
          <div class="py-2 text-sm italic opacity-50">No events yet</div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div
        class="overflow-hidden rounded-2xl border border-border/70 bg-background"
      >
        <div class="border-b border-border/50 bg-muted/5 p-3">
          <span class="text-xs font-semibold tracking-wide uppercase opacity-80"
            >Quick Actions</span
          >
        </div>
        <div class="grid grid-cols-2 gap-2 p-4">
          <button
            id="qa-track"
            class="rounded-lg border border-border/70 px-3 py-2 text-xs font-medium transition-colors hover:bg-accent/10 hover:text-accent disabled:opacity-50"
            >Track Order</button
          >
          <button
            id="qa-refresh"
            class="rounded-lg border border-border/70 px-3 py-2 text-xs font-medium transition-colors hover:bg-accent/10 hover:text-accent disabled:opacity-50"
            >Refresh Session</button
          >
          <button
            id="qa-clear-cart"
            class="rounded-lg border border-border/70 px-3 py-2 text-xs font-medium transition-colors hover:bg-accent/10 hover:text-accent disabled:opacity-50"
            >Clear Cart</button
          >
          <button
            id="qa-delete-session"
            class="rounded-lg border border-red-500/30 px-3 py-2 text-xs font-medium text-red-500 transition-colors hover:bg-red-500/10 disabled:opacity-50"
            >Delete Session</button
          >
          <button
            id="qa-load-profile"
            class="col-span-2 rounded-lg border border-border/70 px-3 py-2 text-xs font-medium transition-colors hover:bg-accent/10 hover:text-accent disabled:opacity-50"
            >Load User Profile</button
          >
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { initMaleeDebug } from "@/scripts/agent/malee/ui";
  document.addEventListener("astro:page-load", () => {
    initMaleeDebug();
  });
</script>

<style>
  @media (prefers-reduced-motion: reduce) {
    *,
    ::before,
    ::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
