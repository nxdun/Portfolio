---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/core/Header.astro";
import Footer from "@/components/core/Footer.astro";

const apiUrl = import.meta.env.PUBLIC_MALEE_API_URL;
---

<Layout title="Malee Agent Debug | ~/nadzu" useBackendApi={true}>
  <Header activeNav={undefined} />

  <main id="malee-debug-root" class="max-w-[1800px] w-full mx-auto px-4 sm:px-8 py-6 flex flex-col lg:flex-row items-start gap-6">
    <!-- Left column: Chat Interface -->
    <div class="flex-1 min-w-0 w-full flex flex-col border border-border/70 bg-background rounded-2xl overflow-hidden h-[calc(100vh-140px)] max-h-[850px]">
      
      <!-- Header Bar -->
      <div class="flex items-center justify-between p-4 border-b border-border/70 bg-muted/10 shrink-0">
        <div>
          <h1 class="text-lg font-bold">Malee Debug Console</h1>
          <p class="text-xs opacity-70 flex items-center gap-2 mt-0.5">
            <span class="font-mono">{apiUrl}</span>
            <span id="status-dot" class="w-2.5 h-2.5 rounded-full bg-red-500 shrink-0 inline-block mt-0.5"></span>
            <span id="session-id-display" class="font-medium">No active session</span>
          </p>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <button id="btn-clear-chat" class="px-3 py-1.5 text-xs font-semibold rounded-lg border border-border/70 hover:bg-muted/20 transition-colors">
            Clear Chat
          </button>
          <button id="btn-new-session" class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-accent text-background hover:opacity-90 transition-opacity">
            New Session
          </button>
        </div>
      </div>

      <!-- Chat Messages -->
      <div id="chat-messages" class="flex-1 overflow-y-auto p-4 flex flex-col gap-2 relative scroll-smooth">
        <div id="chat-empty-state" class="flex h-full items-center justify-center text-sm opacity-50 italic">
          Start chatting
        </div>
      </div>

      <!-- Input Bar -->
      <div class="p-4 border-t border-border/70 bg-muted/10 shrink-0 flex items-center gap-3">
        <select id="chat-lang-select" class="text-xs bg-background border border-border/70 rounded-lg px-2 py-2 focus:outline-none focus:border-accent">
          <option value="auto">Auto</option>
          <option value="english">English</option>
          <option value="sinhala">Sinhala</option>
          <option value="mixed">Mixed</option>
        </select>
        
        <input 
          id="chat-input" 
          type="text" 
          placeholder="Type your message..." 
          class="flex-1 bg-background border border-border/70 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-accent"
          autocomplete="off"
        />
        
        <button id="chat-send-btn" class="px-5 py-2 text-sm font-semibold rounded-lg bg-accent text-background hover:opacity-90 transition-opacity disabled:opacity-50">
          Send
        </button>
      </div>
    </div>

    <!-- Right column: Debug Panel -->
    <div class="w-full lg:w-[360px] xl:w-[420px] 2xl:w-[500px] shrink-0 flex flex-col gap-4">
      
      <!-- Session State -->
      <div id="panel-session" class="debug-panel-section border border-border/70 bg-background rounded-2xl overflow-hidden">
        <div class="section-header p-3 border-b border-border/50 bg-muted/5 flex items-center justify-between cursor-pointer hover:bg-muted/10 transition-colors">
          <span class="text-xs font-semibold tracking-wide opacity-80 uppercase">Session State</span>
          <span class="section-icon text-xs opacity-60">▼</span>
        </div>
        <div id="panel-session-content" class="section-content p-4">
          <div class="text-sm opacity-50 italic py-2">Waiting for session...</div>
        </div>
      </div>

      <!-- Cart -->
      <div id="panel-cart" class="debug-panel-section border border-border/70 bg-background rounded-2xl overflow-hidden">
        <div class="section-header p-3 border-b border-border/50 bg-muted/5 flex items-center justify-between cursor-pointer hover:bg-muted/10 transition-colors">
          <span class="text-xs font-semibold tracking-wide opacity-80 uppercase">Cart</span>
          <span class="section-icon text-xs opacity-60">▼</span>
        </div>
        <div id="panel-cart-content" class="section-content p-4">
          <div class="text-sm opacity-50 italic py-2">Cart is empty</div>
        </div>
      </div>

      <!-- Profile -->
      <div id="panel-profile" class="debug-panel-section border border-border/70 bg-background rounded-2xl overflow-hidden">
        <div class="section-header p-3 border-b border-border/50 bg-muted/5 flex items-center justify-between cursor-pointer hover:bg-muted/10 transition-colors">
          <span class="text-xs font-semibold tracking-wide opacity-80 uppercase">User Profile</span>
          <span class="section-icon text-xs opacity-60">▼</span>
        </div>
        <div id="panel-profile-content" class="section-content p-4">
          <div class="text-sm opacity-50 italic py-2">Profile not loaded</div>
        </div>
      </div>

      <!-- SSE Event Log -->
      <div id="panel-log" class="debug-panel-section border border-border/70 bg-background rounded-2xl overflow-hidden flex-1 flex flex-col max-h-[400px]">
        <div class="section-header p-3 border-b border-border/50 bg-muted/5 flex items-center justify-between cursor-pointer hover:bg-muted/10 transition-colors">
          <div class="flex items-center gap-3">
            <span class="text-xs font-semibold tracking-wide opacity-80 uppercase">SSE Event Log</span>
            <button id="btn-clear-log" class="text-[10px] bg-border/50 hover:bg-border/80 px-2 py-0.5 rounded transition-colors" onclick="event.stopPropagation()">Clear Log</button>
          </div>
          <span class="section-icon text-xs opacity-60">▼</span>
        </div>
        <div id="panel-log-content" class="section-content p-3 flex-1 overflow-y-auto bg-black/5 dark:bg-black/20">
          <div class="text-sm opacity-50 italic py-2">No events yet</div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="border border-border/70 bg-background rounded-2xl overflow-hidden">
        <div class="p-3 border-b border-border/50 bg-muted/5">
          <span class="text-xs font-semibold tracking-wide opacity-80 uppercase">Quick Actions</span>
        </div>
        <div class="p-4 grid grid-cols-2 gap-2">
          <button id="qa-track" class="px-3 py-2 text-xs font-medium rounded-lg border border-border/70 hover:bg-accent/10 hover:text-accent transition-colors disabled:opacity-50">Track Order</button>
          <button id="qa-refresh" class="px-3 py-2 text-xs font-medium rounded-lg border border-border/70 hover:bg-accent/10 hover:text-accent transition-colors disabled:opacity-50">Refresh Session</button>
          <button id="qa-clear-cart" class="px-3 py-2 text-xs font-medium rounded-lg border border-border/70 hover:bg-accent/10 hover:text-accent transition-colors disabled:opacity-50">Clear Cart</button>
          <button id="qa-delete-session" class="px-3 py-2 text-xs font-medium rounded-lg border border-red-500/30 hover:bg-red-500/10 text-red-500 transition-colors disabled:opacity-50">Delete Session</button>
          <button id="qa-load-profile" class="px-3 py-2 text-xs font-medium rounded-lg border border-border/70 hover:bg-accent/10 hover:text-accent transition-colors disabled:opacity-50 col-span-2">Load User Profile</button>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { initMaleeDebug } from "@/scripts/agent/malee/ui";
  document.addEventListener("astro:page-load", () => {
    initMaleeDebug();
  });
</script>

<style>
  @media (prefers-reduced-motion: reduce) {
    *, ::before, ::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
