---
import maleeAvatar from "../../../assets/malee/malee-avatar.png";
---

<main class="conversation-canvas">
  <div
    class="welcome-hero relative flex h-full flex-col items-center justify-center overflow-hidden pt-12 pb-24 select-none"
  >
    <!-- Deep atmospheric layers (removed per user request) -->
    <div class="pointer-events-none absolute inset-0"></div>

    <!-- Slow-rotating Malee flower avatar -->
    <div class="group relative z-10 mb-6">
      <!-- Outer orbital ring -->
      <div
        class="absolute inset-[-16px] animate-[spin_25s_linear_infinite] rounded-full border border-white/[0.04]"
      >
      </div>
      <!-- Middle orbital ring (counter-rotate) -->
      <div
        class="absolute inset-[-8px] animate-[spin_18s_linear_infinite_reverse] rounded-full border border-dashed border-accent/[0.08]"
      >
      </div>

      <!-- The flower itself -->
      <div
        class="h-24 w-24 animate-[spin_30s_linear_infinite] transition-all duration-1000 group-hover:animate-none sm:h-28 sm:w-28"
      >
        <img
          src={maleeAvatar.src}
          alt="Malee"
          class="h-full w-full object-contain drop-shadow-[0_0_30px_rgba(168,130,255,0.35)] transition-all duration-1000 group-hover:scale-110 group-hover:drop-shadow-[0_0_50px_rgba(168,130,255,0.6)]"
        />
      </div>

      <!-- Tiny orbiting particle -->
      <div class="absolute inset-[-24px] animate-[spin_8s_linear_infinite]">
        <div
          class="absolute top-0 left-1/2 h-1.5 w-1.5 -translate-x-1/2 rounded-full bg-accent/60 shadow-[0_0_8px_rgba(var(--color-accent),0.6)]"
        >
        </div>
      </div>
    </div>

    <!-- Typography cluster -->
    <div
      class="relative z-10 mx-auto flex max-w-2xl flex-col items-center px-4 text-center"
    >
      <!-- Top accent line -->
      <div
        class="mb-4 h-px w-6 bg-gradient-to-r from-transparent via-accent/50 to-transparent"
      >
      </div>

      <!-- Kicker -->
      <span
        class="mb-3 font-mono text-[9px] font-bold tracking-[0.4em] text-white/40 uppercase"
      >
        Floral Intelligence
      </span>

      <!-- Hero headline — split into two distinct visual weights -->
      <h2 class="mb-2">
        <span
          class="block text-3xl leading-tight font-extralight tracking-normal text-white/90 sm:text-5xl"
        >
          Tell me what
        </span>
        <span
          class="block text-3xl leading-tight font-light tracking-wide text-white italic sm:text-5xl"
        >
          you're dreaming of.
        </span>
      </h2>

      <!-- Sub-copy -->
      <p
        class="mx-auto mt-2 mb-6 max-w-sm text-[11px] leading-relaxed font-light tracking-wide text-white/30 sm:text-xs"
      >
        Arrangements, gifts, or a surprise for someone special — describe it and
        I'll handle the rest.
      </p>

      <!-- Bottom accent line -->
      <div
        class="mb-6 h-px w-8 bg-gradient-to-r from-transparent via-white/10 to-transparent"
      >
      </div>
    </div>

    <!-- Quick-start action chips -->
    <div
      class="suggestion-bubbles relative z-10 mx-auto flex max-w-xl flex-wrap justify-center gap-3 px-4"
    >
      <button
        class="suggestion-pill group/pill relative overflow-hidden rounded-full border border-white/[0.08] bg-transparent px-6 py-3 font-mono text-[10px] font-bold tracking-[0.15em] text-white/60 uppercase backdrop-blur-sm transition-all duration-700 hover:border-white/25 hover:text-white"
      >
        <span class="relative z-10">Explore Bouquets</span>
        <div
          class="absolute inset-0 bg-gradient-to-r from-accent/10 to-purple-500/10 opacity-0 transition-opacity duration-700 group-hover/pill:opacity-100"
        >
        </div>
      </button>
      <button
        class="suggestion-pill group/pill relative overflow-hidden rounded-full border border-white/[0.08] bg-transparent px-6 py-3 font-mono text-[10px] font-bold tracking-[0.15em] text-white/60 uppercase backdrop-blur-sm transition-all duration-700 hover:border-white/25 hover:text-white"
      >
        <span class="relative z-10">Track Order</span>
        <div
          class="absolute inset-0 bg-gradient-to-r from-accent/10 to-purple-500/10 opacity-0 transition-opacity duration-700 group-hover/pill:opacity-100"
        >
        </div>
      </button>
      <button
        class="suggestion-pill group/pill relative overflow-hidden rounded-full border border-white/[0.08] bg-transparent px-6 py-3 font-mono text-[10px] font-bold tracking-[0.15em] text-white/60 uppercase backdrop-blur-sm transition-all duration-700 hover:border-white/25 hover:text-white"
      >
        <span class="relative z-10">Gift Someone</span>
        <div
          class="absolute inset-0 bg-gradient-to-r from-accent/10 to-purple-500/10 opacity-0 transition-opacity duration-700 group-hover/pill:opacity-100"
        >
        </div>
      </button>
      <button
        class="suggestion-pill group/pill relative overflow-hidden rounded-full border border-white/[0.08] bg-transparent px-6 py-3 font-mono text-[10px] font-bold tracking-[0.15em] text-white/60 uppercase backdrop-blur-sm transition-all duration-700 hover:border-white/25 hover:text-white"
      >
        <span class="relative z-10">Just Browsing</span>
        <div
          class="absolute inset-0 bg-gradient-to-r from-accent/10 to-purple-500/10 opacity-0 transition-opacity duration-700 group-hover/pill:opacity-100"
        >
        </div>
      </button>
    </div>
  </div>

  <div
    id="component-canvas"
    class="pointer-events-none fixed top-0 bottom-0 left-0 z-10 hidden w-[60%] flex-col items-center justify-center px-8 pt-24 pb-32 lg:flex [&>*]:pointer-events-auto"
  >
    <!-- Rich components injected here -->
  </div>

  <div class="messages-area relative z-20 hidden">
    <!-- Messages injected by JS -->
  </div>
</main>
