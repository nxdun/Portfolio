---
import maleeAvatar from "../../../assets/malee/malee-avatar.png";
---
<main class="conversation-canvas">
  <div class="welcome-hero flex flex-col items-center justify-center h-full relative select-none overflow-hidden pt-12 pb-24">
    
    <!-- Deep atmospheric layers (removed per user request) -->
    <div class="absolute inset-0 pointer-events-none">
    </div>

    <!-- Slow-rotating Malee flower avatar -->
    <div class="relative mb-6 z-10 group">
      <!-- Outer orbital ring -->
      <div class="absolute inset-[-16px] border border-white/[0.04] rounded-full animate-[spin_25s_linear_infinite]"></div>
      <!-- Middle orbital ring (counter-rotate) -->
      <div class="absolute inset-[-8px] border border-dashed border-accent/[0.08] rounded-full animate-[spin_18s_linear_infinite_reverse]"></div>
      
      <!-- The flower itself -->
      <div class="w-24 h-24 sm:w-28 sm:h-28 animate-[spin_30s_linear_infinite] group-hover:animate-none transition-all duration-1000">
        <img 
          src={maleeAvatar.src} 
          alt="Malee" 
          class="w-full h-full object-contain drop-shadow-[0_0_30px_rgba(168,130,255,0.35)] group-hover:drop-shadow-[0_0_50px_rgba(168,130,255,0.6)] transition-all duration-1000 group-hover:scale-110"
        />
      </div>
      
      <!-- Tiny orbiting particle -->
      <div class="absolute inset-[-24px] animate-[spin_8s_linear_infinite]">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1.5 h-1.5 bg-accent/60 rounded-full shadow-[0_0_8px_rgba(var(--color-accent),0.6)]"></div>
      </div>
    </div>

    <!-- Typography cluster -->
    <div class="relative z-10 flex flex-col items-center text-center max-w-2xl mx-auto px-4">
      
      <!-- Top accent line -->
      <div class="w-6 h-px bg-gradient-to-r from-transparent via-accent/50 to-transparent mb-4"></div>
      
      <!-- Kicker -->
      <span class="text-[9px] font-mono uppercase tracking-[0.4em] font-bold text-white/40 mb-3">
        Floral Intelligence
      </span>
      
      <!-- Hero headline — split into two distinct visual weights -->
      <h2 class="mb-2">
        <span class="block text-3xl sm:text-5xl font-extralight tracking-normal text-white/90 leading-tight">
          Tell me what
        </span>
        <span class="block text-3xl sm:text-5xl italic font-light tracking-wide text-white leading-tight">
          you're dreaming of.
        </span>
      </h2>
      
      <!-- Sub-copy -->
      <p class="text-white/30 text-[11px] sm:text-xs font-light tracking-wide leading-relaxed mt-2 mb-6 max-w-sm mx-auto">
        Arrangements, gifts, or a surprise for someone special — describe it and I'll handle the rest.
      </p>
      
      <!-- Bottom accent line -->
      <div class="w-8 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mb-6"></div>
    </div>

    <!-- Quick-start action chips -->
    <div class="suggestion-bubbles relative z-10 flex flex-wrap justify-center gap-3 max-w-xl mx-auto px-4">
      <button class="suggestion-pill group/pill relative px-6 py-3 rounded-full bg-transparent border border-white/[0.08] text-white/60 font-mono uppercase text-[10px] tracking-[0.15em] font-bold hover:text-white hover:border-white/25 transition-all duration-700 backdrop-blur-sm overflow-hidden">
        <span class="relative z-10">Explore Bouquets</span>
        <div class="absolute inset-0 bg-gradient-to-r from-accent/10 to-purple-500/10 opacity-0 group-hover/pill:opacity-100 transition-opacity duration-700"></div>
      </button>
      <button class="suggestion-pill group/pill relative px-6 py-3 rounded-full bg-transparent border border-white/[0.08] text-white/60 font-mono uppercase text-[10px] tracking-[0.15em] font-bold hover:text-white hover:border-white/25 transition-all duration-700 backdrop-blur-sm overflow-hidden">
        <span class="relative z-10">Track Order</span>
        <div class="absolute inset-0 bg-gradient-to-r from-accent/10 to-purple-500/10 opacity-0 group-hover/pill:opacity-100 transition-opacity duration-700"></div>
      </button>
      <button class="suggestion-pill group/pill relative px-6 py-3 rounded-full bg-transparent border border-white/[0.08] text-white/60 font-mono uppercase text-[10px] tracking-[0.15em] font-bold hover:text-white hover:border-white/25 transition-all duration-700 backdrop-blur-sm overflow-hidden">
        <span class="relative z-10">Gift Someone</span>
        <div class="absolute inset-0 bg-gradient-to-r from-accent/10 to-purple-500/10 opacity-0 group-hover/pill:opacity-100 transition-opacity duration-700"></div>
      </button>
      <button class="suggestion-pill group/pill relative px-6 py-3 rounded-full bg-transparent border border-white/[0.08] text-white/60 font-mono uppercase text-[10px] tracking-[0.15em] font-bold hover:text-white hover:border-white/25 transition-all duration-700 backdrop-blur-sm overflow-hidden">
        <span class="relative z-10">Just Browsing</span>
        <div class="absolute inset-0 bg-gradient-to-r from-accent/10 to-purple-500/10 opacity-0 group-hover/pill:opacity-100 transition-opacity duration-700"></div>
      </button>
    </div>
  </div>

  <div class="messages-area hidden">
    <!-- Messages injected by JS -->
  </div>

</main>
