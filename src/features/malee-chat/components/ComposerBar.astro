---
import chatSendImg from "../../../assets/malee/chat-send.png";
---

<footer
  class="composer-bar pointer-events-none z-50 flex w-full shrink-0 justify-center px-4 pt-3 pb-9"
>
  <div class="composer-shell pointer-events-auto relative w-full max-w-[780px]">
    {/* ── Layered ambient bloom — soft lotus-light rising from below ── */}
    <div class="bloom-field" aria-hidden="true">
      <span class="bloom bloom-1"></span>
      <span class="bloom bloom-2"></span>
      <span class="bloom bloom-3"></span>
    </div>

    {/* ── Drifting petal motes ── */}
    <div class="petal-motes" aria-hidden="true">
      <span class="mote m1"></span>
      <span class="mote m2"></span>
      <span class="mote m3"></span>
      <span class="mote m4"></span>
    </div>

    {/* ── The bar itself — asymmetric "leaf" silhouette ── */}
    <div
      class="composer-inner group relative flex w-full items-end gap-1.5 p-2.5 backdrop-blur-2xl transition-all duration-[700ms] ease-out"
    >
      {/* Living border — hand-drawn Kandyan liyavel that breathes on focus */}
      <svg class="liya-frame" viewBox="0 0 780 88" preserveAspectRatio="none" aria-hidden="true">
        <defs>
          <linearGradient id="liyaStroke" x1="0" y1="0" x2="780" y2="88" gradientUnits="userSpaceOnUse">
            <stop stop-color="#f9a8d4" stop-opacity="0.35" />
            <stop offset="0.5" stop-color="#e9d5ff" stop-opacity="0.5" />
            <stop offset="1" stop-color="#f472b6" stop-opacity="0.35" />
          </linearGradient>
          <filter id="liyaGlow" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="2.4" result="b" />
            <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
          </filter>
        </defs>
        {/* the enclosing organic capsule */}
        <path
          class="liya-path"
          d="M44 4 H736 C758 4 776 22 776 44 C776 66 758 84 736 84 H44 C22 84 4 66 4 44 C4 22 22 4 44 4 Z"
          fill="none"
          stroke="url(#liyaStroke)"
          stroke-width="1.3"
          filter="url(#liyaGlow)"
        />
        {/* curling nari-latha tendril, top-left */}
        <path
          class="liya-tendril"
          d="M40 4 C18 -6 -2 8 6 26 C10 16 22 12 30 18 C22 24 24 34 34 34"
          fill="none"
          stroke="#f9a8d4"
          stroke-opacity="0.55"
          stroke-width="1.1"
          stroke-linecap="round"
        />
      </svg>

      {/* Glass fill sitting inside the drawn frame */}
      <span class="glass-fill" aria-hidden="true"></span>

      {/* ── Language toggle — a blooming araliya (frangipani) ── */}
      <button
        type="button"
        class="lang-toggle relative z-10 mb-0.5 ml-1 flex h-[54px] w-[54px] shrink-0 items-center justify-center rounded-full outline-none transition-transform duration-500 hover:scale-105 active:scale-95"
        aria-label="Toggle language · භාෂාව මාරු කරන්න"
      >
        <svg class="araliya" viewBox="0 0 60 60" aria-hidden="true">
          <g class="petals">
            <ellipse cx="30" cy="15" rx="8" ry="14" fill="url(#pet)" />
            <ellipse cx="30" cy="15" rx="8" ry="14" fill="url(#pet)" transform="rotate(72 30 30)" />
            <ellipse cx="30" cy="15" rx="8" ry="14" fill="url(#pet)" transform="rotate(144 30 30)" />
            <ellipse cx="30" cy="15" rx="8" ry="14" fill="url(#pet)" transform="rotate(216 30 30)" />
            <ellipse cx="30" cy="15" rx="8" ry="14" fill="url(#pet)" transform="rotate(288 30 30)" />
          </g>
          <circle cx="30" cy="30" r="6" fill="#fde68a" fill-opacity="0.85" />
          <defs>
            <radialGradient id="pet" cx="50%" cy="90%" r="80%">
              <stop offset="0%" stop-color="#fde68a" stop-opacity="0.9" />
              <stop offset="55%" stop-color="#fbcfe8" stop-opacity="0.85" />
              <stop offset="100%" stop-color="#f9a8d4" stop-opacity="0.6" />
            </radialGradient>
          </defs>
        </svg>
        <span class="lang-label lang-en">EN</span>
        <span class="lang-label lang-si">සිං</span>
      </button>

      {/* ── Input ── */}
      <textarea
        class="chat-input relative z-10 flex-grow resize-none bg-transparent px-4 py-3 text-lg font-light tracking-wide text-rose-50/95 caret-pink-300 placeholder-rose-200/30 outline-none sm:text-xl"
        rows="1"
        placeholder="ඔබ අද සොයන්නේ කුමක්ද?  ·  What are you looking for today?"></textarea>

      {/* ── Send — folded petal that unfurls ── */}
      <button
        type="button"
        class="send-btn group/send relative z-10 mr-0.5 mb-0.5 flex h-[58px] w-[58px] shrink-0 items-center justify-center rounded-full transition-transform duration-[600ms] ease-out hover:scale-[1.07] active:scale-90"
        aria-label="Send · යවන්න"
      >
        <span class="send-bloom" aria-hidden="true"></span>
        <img
          src={chatSendImg.src}
          alt="Send"
          class="relative h-9 w-9 object-contain transition-all duration-500 group-hover/send:-translate-y-0.5 group-hover/send:rotate-[10deg] group-hover/send:drop-shadow-[0_0_14px_rgba(253,224,138,0.8)]"
        />
      </button>
    </div>

    {/* ── thin ground-line reflection ── */}
    <div class="ground-glint" aria-hidden="true"></div>
  </div>
</footer>

<style>
  .composer-shell { --ink: 20 12 24; }

  /* ── Ambient lotus bloom rising from below ─────────── */
  .bloom-field { position: absolute; inset: -40% -10% -70%; z-index: 0; filter: blur(30px); pointer-events: none; }
  .bloom { position: absolute; bottom: 0; border-radius: 50%; opacity: 0.5; mix-blend-mode: screen; }
  .bloom-1 { left: 12%; width: 46%; height: 130%; background: radial-gradient(circle at 50% 100%, rgba(249,168,212,0.5), transparent 65%); animation: breathe 7s ease-in-out infinite; }
  .bloom-2 { right: 10%; width: 44%; height: 120%; background: radial-gradient(circle at 50% 100%, rgba(192,132,252,0.45), transparent 65%); animation: breathe 9s ease-in-out infinite 1s; }
  .bloom-3 { left: 34%; width: 40%; height: 140%; background: radial-gradient(circle at 50% 100%, rgba(253,224,138,0.28), transparent 60%); animation: breathe 11s ease-in-out infinite 0.5s; }
  @keyframes breathe {
    0%,100% { transform: translateY(6px) scale(0.98); opacity: 0.4; }
    50%     { transform: translateY(-6px) scale(1.04); opacity: 0.62; }
  }

  /* ── Drifting petal motes ──────────────────────────── */
  .petal-motes { position: absolute; inset: -60% 0 0; z-index: 1; pointer-events: none; }
  .mote {
    position: absolute; bottom: 12%;
    width: 7px; height: 9px;
    background: linear-gradient(160deg, #fbcfe8, #f9a8d4);
    border-radius: 50% 50% 50% 0;
    opacity: 0;
    filter: blur(0.3px);
    animation: float-up 9s ease-in infinite;
  }
  .m1 { left: 18%; animation-delay: 0s; }
  .m2 { left: 42%; animation-delay: 2.6s; }
  .m3 { left: 64%; animation-delay: 4.8s; }
  .m4 { left: 82%; animation-delay: 6.9s; }
  @keyframes float-up {
    0%   { transform: translateY(0) rotate(0) scale(0.7); opacity: 0; }
    12%  { opacity: 0.8; }
    80%  { opacity: 0.5; }
    100% { transform: translateY(-160px) rotate(220deg) scale(1); opacity: 0; }
  }

  /* ── Inner glass fill (clipped to capsule shape) ───── */
  .composer-inner { border-radius: 44px; }
  .glass-fill {
    position: absolute; inset: 0; z-index: 0;
    border-radius: 44px;
    background:
      linear-gradient(160deg, rgba(255,255,255,0.06), rgba(255,255,255,0.01) 40%),
      rgba(var(--ink), 0.72);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), 0 26px 70px rgba(0,0,0,0.6);
    transition: background 0.7s ease, box-shadow 0.7s ease;
  }
  .composer-inner:focus-within .glass-fill {
    background:
      linear-gradient(160deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02) 40%),
      rgba(26, 15, 30, 0.86);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.14), 0 30px 84px rgba(0,0,0,0.66), 0 0 50px rgba(249,168,212,0.14);
  }

  /* ── Living liyavel frame ──────────────────────────── */
  .liya-frame { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 2; pointer-events: none; overflow: visible; }
  .liya-path {
    stroke-dasharray: 6 0;
    transition: stroke-width 0.7s ease, stroke-opacity 0.7s ease;
  }
  .composer-inner:focus-within .liya-path { stroke-width: 1.8; }
  .liya-tendril {
    stroke-dasharray: 120;
    stroke-dashoffset: 120;
    transition: stroke-dashoffset 1.1s cubic-bezier(0.65,0,0.35,1);
