    /* ── Araliya language flower ───────────────────────── */
  .araliya { width: 46px; height: 46px; transition: transform 0.7s cubic-bezier(0.34,1.56,0.64,1); }
  .araliya .petals { transform-origin: 30px 30px; transition: transform 0.7s cubic-bezier(0.34,1.56,0.64,1); }
  .lang-toggle:hover .araliya { transform: rotate(24deg) scale(1.06); }
  .lang-toggle:hover .araliya .petals { transform: rotate(18deg); }
  .lang-toggle:active .araliya .petals { transform: rotate(36deg) scale(0.92); }

  /* language labels — cross-fade EN / සිං */
  .lang-label {
    position: absolute;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #fde68a;
    text-shadow: 0 0 8px rgba(253,224,138,0.55);
    transition: opacity 0.5s ease, transform 0.5s ease;
    pointer-events: none;
  }
  .lang-en { opacity: 1; transform: translateY(0); }
  .lang-si { opacity: 0; transform: translateY(6px); }
  .lang-toggle[data-lang="si"] .lang-en { opacity: 0; transform: translateY(-6px); }
  .lang-toggle[data-lang="si"] .lang-si { opacity: 1; transform: translateY(0); }

  /* ── Chat input ────────────────────────────────────── */
  .chat-input {
    max-height: 200px;
    min-height: 30px;
    line-height: 1.55;
    scrollbar-width: thin;
    scrollbar-color: rgba(249,168,212,0.4) transparent;
  }
  .chat-input::-webkit-scrollbar { width: 6px; }
  .chat-input::-webkit-scrollbar-thumb {
    background: rgba(249,168,212,0.4);
    border-radius: 3px;
  }
  .chat-input::-webkit-scrollbar-track { background: transparent; }

  /* ── Send button — folded petal that unfurls ───────── */
  .send-bloom {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, rgba(253,224,138,0.9), rgba(249,168,212,0.75) 55%, rgba(244,114,182,0.4) 100%);
    box-shadow: 0 6px 20px rgba(244,114,182,0.45), inset 0 1px 0 rgba(255,255,255,0.4);
    transition: transform 0.6s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.6s ease;
  }
  .send-btn:hover .send-bloom {
    transform: scale(1.05);
    box-shadow: 0 8px 28px rgba(244,114,182,0.6), inset 0 1px 0 rgba(255,255,255,0.55), 0 0 30px rgba(253,224,138,0.5);
  }
  .send-btn:active .send-bloom { transform: scale(0.92); }

  /* ── Thin ground-line reflection ───────────────────── */
  .ground-glint {
    position: absolute;
    left: 8%;
    right: 8%;
    bottom: -14px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(249,168,212,0.5), rgba(253,224,138,0.4), rgba(249,168,212,0.5), transparent);
    filter: blur(0.5px);
    opacity: 0.7;
  }

  /* ── Respect reduced-motion preferences ────────────── */
  @media (prefers-reduced-motion: reduce) {
    .bloom, .mote { animation: none !important; }
    .araliya, .araliya .petals, .liya-path, .liya-tendril, .send-bloom { transition: none !important; }
  }
</style>

<script>
  // Auto-grow textarea
  const input = document.querySelector<HTMLTextAreaElement>(".chat-input");
  if (input) {
    const grow = () => {
      input.style.height = "auto";
      input.style.height = Math.min(input.scrollHeight, 200) + "px";
    };
    input.addEventListener("input", grow);
  }

  // Language toggle (EN ⇄ සිං)
  const langBtn = document.querySelector<HTMLButtonElement>(".lang-toggle");
  langBtn?.addEventListener("click", () => {
    const current = langBtn.getAttribute("data-lang");
    langBtn.setAttribute("data-lang", current === "si" ? "en" : "si");
  });
</script>
